# Sanity CMS — required before the Studio at /studio will work.
# Create a free project at https://www.sanity.io/manage then run:
#   npx sanity@latest init --create-project "Leichhardt Dental" --dataset production
# ...and copy the Project ID into the line below.

VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Cloudinary — only used by sync-media.js / upload-videos.js. The Vite app
# does NOT need these (media is served via public CDN URL, no API calls).
# https://cloudinary.com/console → Settings → API Keys.
# Run uploads with: npm run sync-media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Where sync-media.js reads files from. Default is ./media in this project.
# Point it at the synced Google Drive folder so Nick's uploads flow straight
# through. macOS Drive desktop typical path:
#   /Users/<you>/Library/CloudStorage/GoogleDrive-<email>/My Drive/media
MEDIA_DIR=
