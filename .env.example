# Sanity CMS — project ez5kieuq is already created.
# VITE_SANITY_PROJECT_ID is set — the Studio at /studio should work once
# you log in with a Sanity account that's a member of the project.

VITE_SANITY_PROJECT_ID=ez5kieuq
VITE_SANITY_DATASET=production

# Google Analytics 4 (free) — optional. Create a property at analytics.google.com,
# copy the Measurement ID (looks like G-XXXXXXXXXX) and set it here AND in your
# host's env vars (e.g. Vercel). Leave blank to ship with analytics disabled.
VITE_GA_MEASUREMENT_ID=

# Sanity write token — only needed to run `npm run seed` (one-time).
# Get one at: https://www.sanity.io/manage/personal/project/ez5kieuq/api
# → Add API token → role: Editor → copy the token below.
SANITY_WRITE_TOKEN=

# Cloudinary — only used by sync-media.js / upload-videos.js. The Vite app
# does NOT need these (media is served via public CDN URL, no API calls).
# https://cloudinary.com/console → Settings → API Keys.
# Run uploads with: npm run sync-media
CLOUDINARY_CLOUD_NAME=dzydzte9h
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Where sync-media.js reads files from. Default is ./media in this project.
# Point it at the synced Google Drive folder so Nick's uploads flow straight
# through. macOS Drive desktop typical path:
#   /Users/<you>/Library/CloudStorage/GoogleDrive-<email>/My Drive/media
MEDIA_DIR=
