# Sanity CMS — required before the Studio at /studio will work.
# Create a free project at https://www.sanity.io/manage then run:
#   npx sanity@latest init --create-project "Leichhardt Dental" --dataset production
# ...and copy the Project ID into the line below.

VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Cloudinary — only used by upload-videos.js. The Vite app does NOT need
# these (videos are referenced by public CDN URL, not by API).
# https://cloudinary.com/console → Settings → API Keys.
# Run uploads with: node --env-file=.env upload-videos.js
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
