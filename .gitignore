# Dependencies
node_modules

# Build outputs
dist
build

# Environment files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Large video files (exceed GitHub 100MB limit)
public/videos/*.mp4
public/videos/*.mov

# Media staging — folder structure is committed (.gitkeep files), but actual
# files Nick uploads stay local until pushed to Cloudinary via sync-media.js.
media/**/*
!media/**/
!media/**/.gitkeep

# Cloudinary URL map (regenerated on each upload run)
cloudinary-urls.json
